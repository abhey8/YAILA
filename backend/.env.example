PORT=5001
MONGO_URI=mongodb://localhost:27017/ai-learning-assistant
JWT_SECRET=replace-this
FRONTEND_URL=http://localhost:5173

AI_PRIMARY_PROVIDER=groq
AI_FALLBACK_PROVIDER=gemini
GROQ_API_KEY=
GROQ_CHAT_MODEL=llama-3.1-8b-instant
GEMINI_API_KEY=
GEMINI_CHAT_MODEL=gemini-2.5-flash-lite
GEMINI_EMBEDDING_MODEL=gemini-embedding-001

EMBEDDING_DIMENSIONS=768
EMBEDDING_BATCH_SIZE=32
LOCAL_EMBEDDING_FALLBACK=true

VECTOR_STORE_PROVIDER=mongo
VECTOR_STORE_NAMESPACE=yaila
PERSIST_CHUNK_EMBEDDINGS=true

ENDEE_BASE_URL=http://localhost:8080
ENDEE_AUTH_TOKEN=
ENDEE_INDEX_NAME=document-chunks
ENDEE_SPACE_TYPE=cosine
ENDEE_PRECISION=int16
ENDEE_EF_SEARCH=64
ENDEE_INCLUDE_VECTORS=false

DOCUMENT_UPLOAD_MAX_MB=100
INGESTION_PAGE_BATCH_SIZE=16
INGESTION_CHUNK_BATCH_SIZE=24
INGESTION_WORKER_CONCURRENCY=2
INGESTION_CHECKPOINT_ENABLED=true
INGESTION_PREVIEW_CHARS=24000
INGESTION_DEDUP_REPEATED_PAGES=true
INGESTION_USE_AI_CHUNK_SUMMARIES=false

CHUNK_MAX_CHARS=1400
CHUNK_OVERLAP_CHARS=250
CHUNK_MIN_CHARS=120
MAX_TOTAL_CHUNKS_PER_DOC=400
CHUNK_HEADING_MAX_LENGTH=90
CHUNK_SUMMARY_BATCH_SIZE=6
CHUNK_SUMMARY_MAX_TOKENS=80

RETRIEVAL_TOP_K=6
RETRIEVAL_VECTOR_CANDIDATE_POOL=24
RETRIEVAL_LEXICAL_CANDIDATE_POOL=24
RETRIEVAL_MERGED_CANDIDATE_POOL=36
RETRIEVAL_RERANK_POOL_SIZE=16
RETRIEVAL_FINAL_CONTEXT_SIZE=4
RETRIEVAL_MAX_PER_SECTION=2
RETRIEVAL_CONTEXT_RADIUS=1
RETRIEVAL_NEAR_DUPLICATE_THRESHOLD=0.88

OCR_ENABLED=false
ROADMAP_REFRESH_HOURS=168
RESUME_INGESTION_ON_BOOT=true
